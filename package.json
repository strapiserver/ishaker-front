{
  "name": "ishaker-front",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const path of ['.next','.next-dev']) { try { fs.rmSync(path,{recursive:true,force:true}); } catch (error) { if (error && error.code !== 'ENOENT') throw error; } }\"",
    "predev": "npm run clean",
    "dev": "next dev",
    "prebuild": "npm run clean",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.8.0",
    "@chakra-ui/theme-tools": "^2.1.0",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@next/bundle-analyzer": "^13.3.0",
    "@reduxjs/toolkit": "^2.12.0",
    "framer-motion": "^6",
    "next": "13.5.3",
    "next-seo": "^6.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "5.4.0",
    "react-is": "18.3.1",
    "react-redux": "^9.3.0",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.75",
    "eslint": "8.8.0",
    "eslint-config-next": "12.0.10",
    "typescript": "^5.4.5"
  }
}
